{
  "segmentation_model": "YOLO11 instance segmentation",
  "target_region": "conjunctiva",
  "inference": {
    "selected_mask": "first confidence-ordered predicted mask",
    "mask_threshold": 0.5
  },
  "postprocessing": {
    "resize_interpolation": "nearest",
    "gaussian_kernel_size": 7,
    "gaussian_sigma": 2.0,
    "binary_threshold_after_smoothing": 0.2,
    "morphological_close_kernel": [5, 5],
    "morphological_close_iterations": 3,
    "morphological_open_kernel": [3, 3],
    "retain_largest_connected_component": true,
    "outside_mask_pixel_value": 0
  },
  "output": {
    "format": "JPEG",
    "jpeg_quality": 95
  },
  "segmentation_training_reference": {
    "epochs": 80,
    "image_size": 640,
    "batch_size": 8,
    "optimizer": "AdamW",
    "initial_learning_rate": 0.001,
    "mixed_precision": true
  }
}
